{
  "task": {
    "task_id": "observe_plate_001",
    "task_type": "observe",
    "plate_type": "12-well",
    "objective": "4x",
    "observe_scope": "full_plate",
    "target": {
      "include_detect": true
    },
    "capture": {
      "save_dir": "C:/colony_system/data/tasks/observe_plate_001",
      "filename_pattern": "{well}_{index:03d}_row{row:02d}_col{col:02d}.bmp"
    },
    "motion": {
      "port": "COM3",
      "baudrate": 115200,
      "x_slave": 1,
      "y_slave": 2,
      "profile_vel": 200000,
      "profile_acc": 50000,
      "profile_dec": 50000,
      "timeout_s": 120.0
    },
    "scan": {
      "overlap": 0.1,
      "use_objective_fov": true,
      "fov_override_mm": null,
      "settle_s": 0.8
    },
    "detect": {
      "enabled": true,
      "entrypoint": "vision.vision.detect_pipeline:process_image"
    },
    "output": {
      "result_json": "C:/colony_system/data/tasks/observe_plate_001/result.json"
    }
  }
}
